DISCORD_TOKEN=your-discord-bot-token

# Optional. Used only to clear old slash commands for this server on startup.
DISCORD_GUILD_ID=123456789012345678

# Optional allow-list. Leave blank to let anyone in your server use the bot.
# Use this if you only want certain users to download and queue audio.
ALLOWED_DISCORD_USER_IDS=123456789012345678

# Playback and queue defaults.
COMMAND_PREFIX=!
DEFAULT_VOLUME=0.55
FFMPEG_EXECUTABLE=
LOCAL_MUSIC_DIR=local_music
YOUTUBE_SEARCH_LIMIT=5
YTDLP_DEFAULT_SEARCH=ytsearch
